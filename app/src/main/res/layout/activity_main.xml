        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:text="                  500"
        android:textColor="#67AE6E"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="@+id/guidelineVertical"
        app:layout_constraintTop_toBottomOf="@+id/input_2000" />

    <!-- EditText for 1000 -->
    <EditText
        android:id="@+id/input_1000"
        android:layout_width="82dp"
        android:layout_height="60dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/edittext_background_new"
        android:ems="10"
        android:gravity="center"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="#328E6E"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView5" />

    <!-- EditText for Percentage (remains unchanged) -->
    <EditText
        android:id="@+id/editTextNumber5"
        android:layout_width="119dp"
        android:layout_height="47dp"
        android:layout_marginStart="60dp"
        android:layout_marginTop="364dp"
        android:layout_marginEnd="60dp"
        android:background="@drawable/edittext_background_new"
        android:ems="10"
        android:gravity="center"
        android:hint="النسبة المئوية %"
        android:inputType="number"
        android:padding="12dp"
        android:textColor="#328E6E"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleTextView" />

    <!-- Label "للاستاذ" -->
    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="للاستاذ"
        android:textColor="#0FF213"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/save_bt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.47"
        app:layout_constraintStart_toEndOf="@+id/editTextNumber5"
        app:layout_constraintTop_toBottomOf="@+id/input_new_500"
        app:layout_constraintVertical_bias="0.671" />

    <!-- Label "للمعهد" -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="للمعهد"
        android:textColor="#1C87EB"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/cala_bt"
        app:layout_constraintEnd_toStartOf="@+id/editTextNumber5"
        app:layout_constraintHorizontal_bias="0.567"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/input_new_25"
        app:layout_constraintVertical_bias="0.671" />

    <!-- Calculate Button -->
    <Button
        android:id="@+id/cala_bt"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/button_background_calculate"
        android:text="حساب المجموع"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintEnd_toStartOf="@+id/guidelineVertical2"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextNumber5" />

    <!-- Save Button -->
    <Button
        android:id="@+id/save_bt"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/button_background_save"
        android:text="حفظ"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/guidelineVertical2"
        app:layout_constraintTop_toBottomOf="@+id/editTextNumber5" />

